<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0B0EF"

    android:orientation="vertical">

    <TextView
        android:id="@+id/txtresult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:layout_weight="2"
        android:background="#F0B0EF"
        android:gravity="end|center_vertical"
        android:padding="16dp"
        android:textColor="#fff"
        android:textSize="40sp"
        android:textStyle="bold" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0sp"
        android:layout_weight="8"
        android:stretchColumns="*">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/btnAclear"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="AC" />

            <Button
                android:id="@+id/btnBspace"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="⌫" />

            <Button
                android:id="@+id/btnpercentage"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="%" />

            <Button
                android:id="@+id/btnDivide"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="÷" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/no7"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="7" />

            <Button
                android:id="@+id/no8"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="8" />

            <Button
                android:id="@+id/no9"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="9" />

            <Button
                android:id="@+id/btnMultiply"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="x" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/no4"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="4" />

            <Button
                android:id="@+id/no5"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="5" />

            <Button
                android:id="@+id/no6"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="6" />

            <Button
                android:id="@+id/btnSubtract"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="-" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/no1"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="1" />

            <Button
                android:id="@+id/no2"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="2" />

            <Button
                android:id="@+id/no3"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="3" />

            <Button
                android:id="@+id/btnAdd"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:text="+" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/no00"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="00" />

            <Button
                android:id="@+id/no0"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="0" />

            <Button
                android:id="@+id/btndot"
                style="@style/buttonStyle"
                android:layout_height="match_parent"
                android:text="." />

            <Button
                android:id="@+id/btneual"
                style="@style/operatorBtnStyle"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="=" />
        </TableRow>
    </TableLayout>
</LinearLayout>